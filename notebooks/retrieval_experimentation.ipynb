   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Retrieval Experimentation and Analysis\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook reports two primary metrics:\\n\",\n",
    "    \"- Retrieval accuracy (`Recall@K`, `HitRate@K`)\\n\",\n",
    "    \"- Retrieval latency (mean/p50/p95 in milliseconds)\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from __future__ import annotations\\n\",\n",
    "    \"\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"PROJECT_ROOT = Path.cwd().resolve().parent\\n\",\n",
    "    \"if str(PROJECT_ROOT) not in sys.path:\\n\",\n",
    "    \"    sys.path.insert(0, str(PROJECT_ROOT))\\n\",\n",
    "    \"\\n\",\n",
    "    \"from experiments.retrieval_metrics import evaluate_retrieval, load_jds, load_resumes\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"RESUME_DIR = PROJECT_ROOT / \\\"dataset\\\" / \\\"resumes\\\"\\n\",\n",
    "    \"JD_DIR = PROJECT_ROOT / \\\"dataset\\\" / \\\"jds\\\"\\n\",\n",
    "    \"K_VALUES = [1, 3, 5, 10]\\n\",\n",
    "    \"LATENCY_REPEATS = 25\\n\",\n",
    "    \"\\n\",\n",
    "    \"resumes = load_resumes(str(RESUME_DIR))\\n\",\n",
    "    \"jobs = load_jds(str(JD_DIR))\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Loaded resumes: {len(resumes)}\\\")\\n\",\n",
    "    \"print(f\\\"Loaded JDs: {len(jobs)}\\\")\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1) Accuracy + Latency (strict relevance)\\n\",\n",
    "    \"\\n\",\n",
    "    \"`all_required` relevance mode considers a resume relevant if:\\n\",\n",
    "    \"- all required JD skills are present\\n\",\n",
    "    \"- experience years satisfy the minimum threshold\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"strict_results = evaluate_retrieval(\\n\",\n",
    "    \"    resumes=resumes,\\n\",\n",
    "    \"    jobs=jobs,\\n\",\n",
    "    \"    k_values=K_VALUES,\\n\",\n",
    "    \"    relevance_mode=\\\"all_required\\\",\\n\",\n",
    "    \"    latency_repeats=LATENCY_REPEATS,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"metrics_df = pd.DataFrame(strict_results[\\\"metrics\\\"])\\n\",\n",
    "    \"latency_df = pd.DataFrame(strict_results[\\\"latency_rows\\\"])\\n\",\n",
    "    \"summary = strict_results[\\\"summary\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"display(metrics_df)\\n\",\n",
    "    \"display(latency_df.head())\\n\",\n",
    "    \"summary\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(12, 4))\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[0].plot(metrics_df[\\\"k\\\"], metrics_df[\\\"recall_at_k\\\"], marker=\\\"o\\\", label=\\\"Recall@K\\\")\\n\",\n",
    "    \"axes[0].plot(metrics_df[\\\"k\\\"], metrics_df[\\\"hit_rate_at_k\\\"], marker=\\\"o\\\", label=\\\"HitRate@K\\\")\\n\",\n",
    "    \"axes[0].set_title(\\\"Retrieval Accuracy\\\")\\n\",\n",
    "    \"axes[0].set_xlabel(\\\"K\\\")\\n\",\n",
    "    \"axes[0].set_ylabel(\\\"Score\\\")\\n\",\n",
    "    \"axes[0].set_ylim(0, 1.05)\\n\",\n",
    "    \"axes[0].legend()\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[1].hist(latency_df[\\\"latency_ms\\\"], bins=10, color=\\\"#4F81BD\\\", edgecolor=\\\"white\\\")\\n\",\n",
    "    \"axes[1].set_title(\\\"Latency Distribution (per JD)\\\")\\n\",\n",
    "    \"axes[1].set_xlabel(\\\"Latency (ms)\\\")\\n\",\n",
    "    \"axes[1].set_ylabel(\\\"Count\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2) Relevance Sensitivity Experiment\\n\",\n",
    "    \"\\n\",\n",
    "    \"Compare three relevance definitions:\\n\",\n",
    "    \"- `all_required`\\n\",\n",
    "    \"- `half_required`\\n\",\n",
    "    \"- `any_required`\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"modes = [\\\"all_required\\\", \\\"half_required\\\", \\\"any_required\\\"]\\n\",\n",
    "    \"rows = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for mode in modes:\\n\",\n",
    "    \"    result = evaluate_retrieval(\\n\",\n",
    "    \"        resumes=resumes,\\n\",\n",
    "    \"        jobs=jobs,\\n\",\n",
    "    \"        k_values=[5],\\n\",\n",
    "    \"        relevance_mode=mode,\\n\",\n",
    "    \"        latency_repeats=LATENCY_REPEATS,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    metric = result[\\\"metrics\\\"][0]\\n\",\n",
    "    \"    rows.append({\\n\",\n",
    "    \"        \\\"relevance_mode\\\": mode,\\n\",\n",
    "    \"        \\\"recall_at_5\\\": metric[\\\"recall_at_k\\\"],\\n\",\n",
    "    \"        \\\"hit_rate_at_5\\\": metric[\\\"hit_rate_at_k\\\"],\\n\",\n",
    "    \"        \\\"avg_latency_ms\\\": result[\\\"summary\\\"][\\\"avg_latency_ms\\\"],\\n\",\n",
    "    \"        \\\"p95_latency_ms\\\": result[\\\"summary\\\"][\\\"p95_latency_ms\\\"],\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"sensitivity_df = pd.DataFrame(rows)\\n\",\n",
    "    \"display(sensitivity_df)\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3) Final Reporting Block\\n\",\n",
    "    \"\\n\",\n",
    "    \"Use this cell output directly in your report/demo notes.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"report = {\\n\",\n",
    "    \"    \\\"dataset\\\": {\\n\",\n",
    "    \"        \\\"resumes\\\": len(resumes),\\n\",\n",
    "    \"        \\\"jds\\\": len(jobs),\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    \\\"accuracy\\\": metrics_df.to_dict(orient=\\\"records\\\"),\\n\",\n",
    "    \"    \\\"latency_summary_ms\\\": summary,\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"report\\n\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
